<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 主要颜色 -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#34495e" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#3a536b" />
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#2c3e50" />
    
    <!-- 次要颜色 -->
    <SolidColorBrush x:Key="SecondaryBrush" Color="#3498db" />
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#2980b9" />
    <SolidColorBrush x:Key="SecondaryPressedBrush" Color="#1f618d" />
    
    <!-- 文本颜色 -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#2c3e50" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#7f8c8d" />
    <SolidColorBrush x:Key="TextLightBrush" Color="#95a5a6" />
    
    <!-- 背景颜色 -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#F3F6F9" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="White" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#1E1E2D" />
    
    <!-- 边框颜色 -->
    <SolidColorBrush x:Key="BorderBrush" Color="#EBEDF3" />
    <SolidColorBrush x:Key="LightBorderBrush" Color="#F3F6F9" />
    
    <!-- 禁用颜色 -->
    <SolidColorBrush x:Key="DisabledBrush" Color="#bdc3c7" />
    
    <!-- 状态颜色 -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#27ae60" />
    <SolidColorBrush x:Key="WarningBrush" Color="#f39c12" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#e74c3c" />
</ResourceDictionary>