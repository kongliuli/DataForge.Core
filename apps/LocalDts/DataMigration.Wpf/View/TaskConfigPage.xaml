<Page x:Class="DataMigration.Wpf.TaskConfigPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:DataMigration.Wpf"
      xmlns:vm="clr-namespace:DataMigration.Wpf.ViewModel"
      mc:Ignorable="d"
      d:DesignHeight="600"
      d:DesignWidth="1200"
      d:DataContext="{d:DesignInstance Type=vm:TaskConfigViewModel, IsDesignTimeCreatable=True}"
      Title="任务管理">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!-- 左侧：数据源 -->
        <Border Grid.Column="0" Background="#f0f0f0" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="数据源" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
                
                <!-- 任务操作按钮 -->
                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="新建任务" Command="{Binding NewCommand}" Height="25" />
                    <Button Grid.Column="1" Content="加载" Command="{Binding LoadCommand}" Height="25" Margin="5,0,5,0" />
                    <Button Grid.Column="2" Content="保存" Command="{Binding SaveCommand}" Height="25" />
                    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="加载中..." Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,5,0" />
                        <ProgressBar Width="100" Height="10" IsIndeterminate="True" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Grid>
                
                <!-- 任务名称 -->
                <Grid Grid.Row="2" Margin="0,0,0,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="任务名称" Margin="0,0,0,5" />
                    <TextBox Grid.Row="1" Text="{Binding TaskName}" Width="280" />
                </Grid>
                
                <!-- 数据源选择 -->
                <Grid Grid.Row="3" Margin="0,0,0,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="选择数据源" Margin="0,0,0,5" />
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" ItemsSource="{Binding DataSources, IsAsync=True}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedDataSource}" />
                        <Button Grid.Column="1" Content="选择插件" Command="{Binding SelectDataSourceCommand}" Height="22" Margin="10,0,0,0" />
                    </Grid>
                    <Grid Grid.Row="2" Margin="0,5,0,0">
                        <Button Content="配置插件" Command="{Binding ConfigurePluginCommand}" Height="22" />
                    </Grid>
                </Grid>
                
                <!-- 数据表展示（上下排布） -->
                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="数据表" FontSize="14" FontWeight="Bold" Margin="0,10,0,5" />
                    <ListBox Grid.Row="1" x:Name="TablesListBox" ItemsSource="{Binding Tables, IsAsync=True}"
                             VirtualizingPanel.IsVirtualizing="True">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel VirtualizationMode="Recycling" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBlock Text="{Binding}" FontWeight="Bold" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Border>

        <!-- 中间：配置面板 -->
        <Border Grid.Column="1" Background="#f9f9f9" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="配置面板" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" />
                
                <!-- 配置选项卡 -->
                <TabControl Grid.Row="1" x:Name="ConfigTabControl">
                    <!-- 数据源关联选项卡 -->
                    <TabItem Header="数据源关联">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock Text="表关联配置" FontWeight="Bold" Margin="0,0,0,5" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="100" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="源表:" VerticalAlignment="Center" />
                                    <ComboBox Grid.Column="0" ItemsSource="{Binding Tables}" SelectedItem="{Binding SourceTableName, Mode=TwoWay}" SelectionChanged="SourceTable_SelectionChanged" Margin="50,0,0,0" />
                                    <TextBlock Grid.Column="1" Text="源列:" VerticalAlignment="Center" />
                                    <ComboBox Grid.Column="1" ItemsSource="{Binding SourceColumns, IsAsync=True}" SelectedItem="{Binding SourceColumnName, Mode=TwoWay}" Margin="50,0,0,0" />
                                    <TextBlock Grid.Column="2" Text="目标表:" VerticalAlignment="Center" />
                                    <ComboBox Grid.Column="2" ItemsSource="{Binding Tables}" SelectedItem="{Binding TargetTableName, Mode=TwoWay}" SelectionChanged="TargetTable_SelectionChanged" Margin="50,0,0,0" />
                                    <TextBlock Grid.Column="3" Text="目标列:" VerticalAlignment="Center" />
                                    <ComboBox Grid.Column="3" ItemsSource="{Binding TargetColumns, IsAsync=True}" SelectedItem="{Binding TargetColumnName, Mode=TwoWay}" Margin="50,0,0,0" />
                                    <Button Grid.Column="4" Content="添加关联" Command="{Binding AddRelationCommand}" Height="22" />
                                </Grid>
                            </StackPanel>
                            
                            <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                <TextBlock Text="已添加的关联" FontWeight="Bold" Margin="0,0,0,5" />
                                <ListBox ItemsSource="{Binding TableRelations}" Height="200"
                                         VirtualizingPanel.IsVirtualizing="True">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel VirtualizationMode="Recycling" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding SourceTable}" Margin="0,0,5,0" />
                                                <TextBlock Text="." Margin="0,0,5,0" />
                                                <TextBlock Text="{Binding SourceColumn}" Margin="0,0,5,0" />
                                                <TextBlock Text="->" Margin="0,0,5,0" />
                                                <TextBlock Text="{Binding TargetTable}" Margin="0,0,5,0" />
                                                <TextBlock Text="." Margin="0,0,5,0" />
                                                <TextBlock Text="{Binding TargetColumn}" Margin="0,0,5,0" />
                                                <Button Content="删除" Command="{Binding DataContext.RemoveRelationCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" CommandParameter="{Binding}" Height="20" Width="50" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                            
                            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                <TextBlock Text="关联预览" FontWeight="Bold" Margin="0,0,0,5" />
                                <TextBox Text="{Binding PreviewQuery}" IsReadOnly="True" Height="100" TextWrapping="Wrap" AcceptsReturn="True" />
                            </StackPanel>
                        </Grid>
                    </TabItem>
                    
                    <!-- 列重命名映射选项卡 -->
                    <TabItem Header="列重命名映射">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock Text="列重命名配置" FontWeight="Bold" Margin="0,0,0,5" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="100" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="原始列名:" VerticalAlignment="Center" />
                                    <ComboBox Grid.Column="0" ItemsSource="{Binding SourceColumns}" SelectedItem="{Binding OriginalColumnName, Mode=TwoWay}" Margin="80,0,0,0" />
                                    <TextBlock Grid.Column="1" Text="新列名:" VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1" Text="{Binding NewColumnName, Mode=TwoWay}" Margin="60,0,0,0" />
                                    <Button Grid.Column="2" Content="添加映射" Command="{Binding AddColumnRenameMappingCommand}" Height="22" />
                                </Grid>
                            </StackPanel>
                            
                            <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                <TextBlock Text="已添加的映射" FontWeight="Bold" Margin="0,0,0,5" />
                                <DataGrid ItemsSource="{Binding ColumnRenameMappings}" Height="200" AutoGenerateColumns="False"
                                          EnableRowVirtualization="True" EnableColumnVirtualization="True"
                                          VirtualizingPanel.IsVirtualizing="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="原始列名" Binding="{Binding OriginalColumnName}" />
                                        <DataGridTextColumn Header="新列名" Binding="{Binding NewColumnName}" />
                                        <DataGridTemplateColumn Header="操作">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="删除" Command="{Binding DataContext.RemoveColumnRenameMappingCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" CommandParameter="{Binding}" Height="20" Width="50" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                            
                            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                <Button Content="预览重命名效果" Command="{Binding PreviewRenameEffectCommand}" Height="22" />
                            </StackPanel>
                        </Grid>
                    </TabItem>
                    
                    <!-- 字段映射选项卡 -->
                    <TabItem Header="字段映射">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock Text="字段映射配置" FontWeight="Bold" Margin="0,0,0,5" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="自动映射" Command="{Binding AutoMapFieldsCommand}" Height="22" Margin="0,0,10,0" />
                                    <Button Content="清除映射" Command="{Binding ClearFieldMappingsCommand}" Height="22" />
                                    <Button Content="加载源字段" Command="{Binding LoadSourceFieldsCommand}" Height="22" Margin="10,0,0,0" />
                                    <Button Content="加载目标字段" Command="{Binding LoadTargetFieldsCommand}" Height="22" Margin="10,0,0,0" />
                                </StackPanel>
                            </StackPanel>
                            
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="数据源字段" FontWeight="Bold" Margin="0,0,0,5" />
                                    <ListBox ItemsSource="{Binding SourceFields, IsAsync=True}" SelectedItem="{Binding SelectedSourceField, Mode=TwoWay}" Height="300"
                                         VirtualizingPanel.IsVirtualizing="True">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel VirtualizationMode="Recycling" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                </ListBox>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Button Content="→" Command="{Binding AddFieldMappingCommand}" Height="30" Width="60" Margin="0,10,0,0" />
                                </StackPanel>
                                
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="目标源字段" FontWeight="Bold" Margin="0,0,0,5" />
                                    <ListBox ItemsSource="{Binding TargetFields, IsAsync=True}" SelectedItem="{Binding SelectedTargetField, Mode=TwoWay}" Height="300"
                                         VirtualizingPanel.IsVirtualizing="True">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel VirtualizationMode="Recycling" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                </ListBox>
                                </StackPanel>
                            </Grid>
                            
                            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                <TextBlock Text="映射预览" FontWeight="Bold" Margin="0,0,0,5" />
                                <DataGrid ItemsSource="{Binding FieldMappings}" Height="100" AutoGenerateColumns="False"
                                          EnableRowVirtualization="True" EnableColumnVirtualization="True"
                                          VirtualizingPanel.IsVirtualizing="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="数据源字段" Binding="{Binding SourceField}" />
                                        <DataGridTextColumn Header="目标源字段" Binding="{Binding TargetField}" />
                                        <DataGridTemplateColumn Header="操作">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="删除" Command="{Binding DataContext.RemoveFieldMappingCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" CommandParameter="{Binding}" Height="20" Width="50" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Grid>
                    </TabItem>
                    
                    <!-- 格式配置选项卡 -->
                    <TabItem Header="格式配置">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock Text="格式配置" FontWeight="Bold" Margin="0,0,0,5" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="100" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="字段:" VerticalAlignment="Center" />
                                    <ComboBox Grid.Column="0" ItemsSource="{Binding SourceFields}" SelectedItem="{Binding SelectedField, Mode=TwoWay}" Margin="50,0,0,0" />
                                    <TextBlock Grid.Column="1" Text="格式类型:" VerticalAlignment="Center" />
                                    <ComboBox Grid.Column="1" SelectedItem="{Binding FormatType, Mode=TwoWay}" Margin="70,0,0,0">
                                        <ComboBoxItem Content="日期" />
                                        <ComboBoxItem Content="时间" />
                                        <ComboBoxItem Content="数字" />
                                        <ComboBoxItem Content="文本" />
                                    </ComboBox>
                                    <TextBlock Grid.Column="2" Text="格式:" VerticalAlignment="Center" />
                                    <TextBox Grid.Column="2" Text="{Binding FormatString, Mode=TwoWay}" Margin="50,0,0,0" />
                                    <Button Grid.Column="3" Content="添加配置" Command="{Binding AddFormatConfigCommand}" Height="22" />
                                </Grid>
                            </StackPanel>
                            
                            <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                <TextBlock Text="已添加的格式配置" FontWeight="Bold" Margin="0,0,0,5" />
                                <DataGrid ItemsSource="{Binding FormatConfigs}" Height="200" AutoGenerateColumns="False"
                                          EnableRowVirtualization="True" EnableColumnVirtualization="True"
                                          VirtualizingPanel.IsVirtualizing="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="字段" Binding="{Binding FieldName}" />
                                        <DataGridTextColumn Header="格式类型" Binding="{Binding FormatType}" />
                                        <DataGridTextColumn Header="格式" Binding="{Binding FormatString}" />
                                        <DataGridTemplateColumn Header="操作">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="删除" Command="{Binding DataContext.RemoveFormatConfigCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" CommandParameter="{Binding}" Height="20" Width="50" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                            
                            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                <Button Content="预览格式效果" Command="{Binding PreviewFormatEffectCommand}" Height="22" />
                            </StackPanel>
                        </Grid>
                    </TabItem>
                    
                    <!-- 配置预览选项卡 -->
                    <TabItem Header="配置预览">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="配置摘要" FontWeight="Bold" Margin="0,0,10,0" />
                                <Button Content="生成摘要" Command="{Binding GenerateConfigSummaryCommand}" Height="22" />
                            </StackPanel>
                            
                            <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                <TextBox Text="{Binding ConfigSummary}" IsReadOnly="True" Height="300" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
                            </StackPanel>
                            
                            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                <Button Content="验证配置" Command="{Binding ValidateConfigCommand}" Height="22" />
                                <TextBlock Text="{Binding ConfigStatus}" Margin="0,10,0,0" />
                            </StackPanel>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>

        <!-- 右侧：目标源 -->
        <Border Grid.Column="2" Background="#f5f5f5" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="目标源" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
                
                <!-- 目标源选择 -->
                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="选择目标源" Margin="0,0,0,5" />
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" ItemsSource="{Binding DataTargets, IsAsync=True}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedDataTarget}" />
                        <Button Grid.Column="1" Content="选择插件" Command="{Binding SelectDataTargetCommand}" Height="22" Margin="10,0,0,0" />
                    </Grid>
                    <Grid Grid.Row="2" Margin="0,5,0,0">
                        <Button Content="配置插件" Command="{Binding ConfigurePluginCommand}" Height="22" />
                    </Grid>
                </Grid>
                
                <!-- 执行任务按钮 -->
                <Button Grid.Row="2" Content="执行任务" Command="{Binding ExecuteCommand}" Width="280" Height="40" Background="#4CAF50" Foreground="White" />
            </Grid>
        </Border>
    </Grid>
</Page>