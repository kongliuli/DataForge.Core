<Page x:Class="DataMigration.Wpf.TaskExecutionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:DataMigration.Wpf"
      xmlns:vm="clr-namespace:DataMigration.Wpf.ViewModel"
      mc:Ignorable="d"
      d:DesignHeight="600"
      d:DesignWidth="800"
      d:DataContext="{d:DesignInstance Type=vm:TaskExecutionViewModel, IsDesignTimeCreatable=True}"
      Title="任务执行">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="任务执行" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" />
        
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="120" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="加载任务" Command="{Binding LoadCommand}" Height="30" />
            <Button Grid.Column="1" Content="开始执行" Command="{Binding StartCommand}" Height="30" Margin="10,0,10,0" />
            <Button Grid.Column="2" Content="停止执行" Command="{Binding StopCommand}" Height="30" />
        </Grid>
        
        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="任务状态" Margin="0,0,0,5" />
            <TextBlock Grid.Row="1" Text="{Binding TaskStatus}" FontWeight="Bold" />
        </Grid>
        
        <!-- 进度信息 -->
        <Grid Grid.Row="3" Margin="0,0,0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="执行进度" Margin="0,0,0,5" />
            <ProgressBar Grid.Row="1" Value="{Binding Progress}" Width="800" Height="20" Margin="0,0,0,5" />
            <StackPanel Grid.Row="2" Orientation="Horizontal">
                <TextBlock Text="{Binding ProgressText}" Margin="0,0,20,0" />
                <TextBlock Text="已处理: {Binding RecordsProcessed}" Margin="0,0,20,0" />
                <TextBlock Text="总记录: {Binding RecordsTotal}" />
            </StackPanel>
        </Grid>
        
        <Grid Grid.Row="4" Margin="0,0,0,5">
            <TextBlock Text="任务详情" />
        </Grid>
        
        <TextBox Grid.Row="5" Text="{Binding TaskDetails}" Width="800" Height="150" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" />
        
        <Grid Grid.Row="6" Margin="0,5,0,5">
            <TextBlock Text="执行日志" />
        </Grid>
        
        <TextBox Grid.Row="7" x:Name="LogTextBox" Text="{Binding Log}" Width="800" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" />
    </Grid>
</Page>