<Window x:Class="DataMigration.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DataMigration.Wpf"
        xmlns:vm="clr-namespace:DataMigration.Wpf.ViewModel"
        xmlns:converters="clr-namespace:DataMigration.Wpf.Converters"
        mc:Ignorable="d"
        Title="数据迁移工具"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=True}">
    <!-- 设计时数据 -->
    <d:Window.DataContext>
        <vm:MainViewModel />
    </d:Window.DataContext>
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDefault.xaml" />
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml" />
                <ResourceDictionary Source="../Resources/Brushes.xaml" />
                <ResourceDictionary Source="../Resources/Styles.xaml" />
                <ResourceDictionary Source="../Resources/Converters.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <!-- 导航按钮样式触发器 -->
            <Style x:Key="NavButtonStyleWithSelection" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                <Style.Triggers>
                    <DataTrigger Value="True">
                        <DataTrigger.Binding>
                            <MultiBinding Converter="{StaticResource EqualsConverter}">
                                <Binding ElementName="CurrentPageHolder" Path="Text" />
                                <Binding RelativeSource="{RelativeSource Self}" Path="Tag" />
                            </MultiBinding>
                        </DataTrigger.Binding>
                        <Setter Property="Background" Value="{StaticResource SecondaryBrush}" />
                        <Setter Property="Foreground" Value="White" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            
            <!-- 卡片阴影效果 -->
            <Style x:Key="CardShadowStyle" TargetType="Border">
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect
                            BlurRadius="10"
                            ShadowDepth="3"
                            Color="#000000"
                            Opacity="0.15"
                            Direction="270" />
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" MinWidth="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 侧边导航栏 -->
        <Border Grid.Column="0" Background="{StaticResource PrimaryBrush}" Padding="15" CornerRadius="0,12,12,0" Effect="{StaticResource CardShadowStyle}">
            <StackPanel>
                <!-- 标题区域 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,10,0,30">
                    <Path Width="36" Height="36" Fill="{StaticResource SecondaryBrush}" Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8Z" />
                    <TextBlock Text="数据迁移工具" FontSize="20" FontWeight="Bold" Foreground="White" Margin="12,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                
                <!-- 导航按钮 -->
                <StackPanel Margin="0,0,0,10" x:Name="NavigationButtons" VerticalAlignment="Stretch">
                    <Button Content="插件管理" Command="{Binding NavigateCommand}" CommandParameter="PluginManagerPage" Style="{StaticResource NavButtonStyleWithSelection}" Tag="PluginManagerPage" Margin="0,0,0,8" />
                    <Button Content="数据源配置" Command="{Binding NavigateCommand}" CommandParameter="DataSourceConfigPage" Style="{StaticResource NavButtonStyleWithSelection}" Tag="DataSourceConfigPage" Margin="0,0,0,8" />
                    <Button Content="目标源配置" Command="{Binding NavigateCommand}" CommandParameter="DataTargetConfigPage" Style="{StaticResource NavButtonStyleWithSelection}" Tag="DataTargetConfigPage" Margin="0,0,0,8" />
                    <Button Content="清洗规则配置" Command="{Binding NavigateCommand}" CommandParameter="TransformerConfigPage" Style="{StaticResource NavButtonStyleWithSelection}" Tag="TransformerConfigPage" Margin="0,0,0,8" />
                    <Button Content="任务管理" Command="{Binding NavigateCommand}" CommandParameter="TaskConfigPage" Style="{StaticResource NavButtonStyleWithSelection}" Tag="TaskConfigPage" Margin="0,0,0,8" />
                    <Button Content="任务执行" Command="{Binding NavigateCommand}" CommandParameter="TaskExecutionPage" Style="{StaticResource NavButtonStyleWithSelection}" Tag="TaskExecutionPage" />
                </StackPanel>
                <TextBlock Text="{Binding CurrentPage}" Visibility="Collapsed" x:Name="CurrentPageHolder" />
                
                <!-- 版本信息 -->
                <StackPanel VerticalAlignment="Bottom" Margin="0,40,0,20">
                    <TextBlock Text="版本 1.0.0" FontSize="12" Foreground="{StaticResource TextLightBrush}" Margin="15,0,0,0" />
                    <TextBlock Text="© 2026 数据迁移工具" FontSize="11" Foreground="{StaticResource TextLightBrush}" Margin="15,5,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 主内容区域 -->
        <Border Grid.Column="1" Background="{StaticResource BackgroundBrush}" Padding="25" CornerRadius="12,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" MinHeight="70" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <!-- 页面标题 -->
                <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Effect="{StaticResource CardShadowStyle}" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="25,15,25,15">
                        <TextBlock Text="{Binding CurrentPageTitle}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>
                
                <!-- 内容区域 -->
                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Effect="{StaticResource CardShadowStyle}" Margin="0,20,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Background="White" BorderThickness="0">
                        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </Grid>
    <Window.Triggers>
        <EventTrigger RoutedEvent="Frame.Navigating" SourceName="MainFrame">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation 
                        Storyboard.TargetName="MainFrame" 
                        Storyboard.TargetProperty="Opacity" 
                        From="1.0" 
                        To="0.0" 
                        Duration="0:0:0.2" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
        <EventTrigger RoutedEvent="Frame.Navigated" SourceName="MainFrame">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation 
                        Storyboard.TargetName="MainFrame" 
                        Storyboard.TargetProperty="Opacity" 
                        From="0.0" 
                        To="1.0" 
                        Duration="0:0:0.3" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>