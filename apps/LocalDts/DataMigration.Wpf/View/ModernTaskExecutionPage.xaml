<Page x:Class="DataMigration.Wpf.View.ModernTaskExecutionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:hc="https://handyorg.github.io/handycontrol"
      xmlns:local="clr-namespace:DataMigration.Wpf.View"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1000"
      Title="现代化任务执行">
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- 顶部控制 -->
            <RowDefinition Height="200" />  <!-- 仪表盘统计 -->
            <RowDefinition Height="*" />    <!-- 日志与详情 -->
        </Grid.RowDefinitions>

        <!-- 1. 顶部状态与控制 -->
        <Border Grid.Row="0" Style="{StaticResource ModernCardStyle}" Margin="20,20,20,10">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <hc:StatusHalo Status="Success" Margin="0,0,15,0" Width="12" Height="12" />
                    <TextBlock Text="任务状态: " FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="正在运行 (迁移中)" FontSize="16" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="开始执行" hc:IconElement.Geometry="{StaticResource PlayGeometry}" 
                            Style="{StaticResource ButtonPrimary}" Width="120" Margin="0,0,10,0" />
                    <Button Content="停止执行" hc:IconElement.Geometry="{StaticResource StopGeometry}" 
                            Style="{StaticResource ButtonDanger}" Width="120" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 2. 仪表盘统计区域 -->
        <UniformGrid Grid.Row="1" Columns="3" Margin="10,0,10,0">
            <!-- 进度 -->
            <Border Style="{StaticResource ModernCardStyle}">
                <Grid>
                    <hc:CircleProgressBar Value="65" Width="100" Height="100" ArcThickness="8" 
                                          FontSize="18" ShowText="True" HorizontalAlignment="Left" />
                    <StackPanel VerticalAlignment="Center" Margin="120,0,0,0">
                        <TextBlock Text="迁移进度" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="65,432 / 100,000" FontSize="16" FontWeight="Bold" Margin="0,5,0,0" />
                        <TextBlock Text="预计剩余: 05:20" FontSize="12" Foreground="{StaticResource TextLightBrush}" Margin="0,5,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 速率 -->
            <Border Style="{StaticResource ModernCardStyle}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="1,240" FontSize="36" FontWeight="Bold" Foreground="{StaticResource SecondaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="条记录 / 秒" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                    <hc:LoadingLine Style="{StaticResource LoadingLineSmall}" Margin="0,10,0,0" />
                </StackPanel>
            </Border>

            <!-- 成功/失败 -->
            <Border Style="{StaticResource ModernCardStyle}">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="成功: 65,430" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" />
                            <TextBlock Text="100%" HorizontalAlignment="Right" Foreground="{StaticResource TextLightBrush}" />
                        </Grid>
                        <hc:ProgressBar Value="100" Height="6" Foreground="{StaticResource SuccessBrush}" Background="{StaticResource LightBorderBrush}" />
                        
                        <Grid Margin="0,15,0,10">
                            <TextBlock Text="失败: 2" Foreground="{StaticResource ErrorBrush}" FontWeight="SemiBold" />
                            <TextBlock Text="0.003%" HorizontalAlignment="Right" Foreground="{StaticResource TextLightBrush}" />
                        </Grid>
                        <hc:ProgressBar Value="0.3" Height="6" Foreground="{StaticResource ErrorBrush}" Background="{StaticResource LightBorderBrush}" />
                    </StackPanel>
                </Grid>
            </Border>
        </UniformGrid>

        <!-- 3. 日志与详情区域 -->
        <Grid Grid.Row="2" Margin="20,10,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 实时日志 -->
            <Border Grid.Column="0" Style="{StaticResource ModernCardStyle}" Margin="0,0,10,0">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,15">
                        <TextBlock Text="实时迁移日志" FontSize="16" FontWeight="Bold" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <CheckBox Content="自动滚动" IsChecked="True" Margin="0,0,15,0" />
                            <Button Content="导出日志" Style="{StaticResource ButtonDefault}" Height="25" Padding="10,0" />
                        </StackPanel>
                    </Grid>
                    <hc:ScrollViewer>
                        <TextBox IsReadOnly="True" BorderThickness="0" TextWrapping="Wrap" 
                                 Background="Transparent" FontSize="13" FontFamily="Consolas"
                                 Text="[2026-04-03 10:15:01] [INFO] 开始迁移表: Users&#x0a;[2026-04-03 10:15:02] [INFO] 已处理 1,000 条记录...&#x0a;[2026-04-03 10:15:03] [INFO] 已处理 2,000 条记录...&#x0a;[2026-04-03 10:15:04] [WARN] 记录 ID=1234 字段 'Email' 为空，已使用默认值。&#x0a;[2026-04-03 10:15:05] [INFO] 已处理 3,000 条记录..." />
                    </hc:ScrollViewer>
                </DockPanel>
            </Border>

            <!-- 任务详情 -->
            <Border Grid.Column="1" Style="{StaticResource ModernCardStyle}" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="任务详情" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" />
                    <hc:PropertyGrid>
                        <!-- 属性展示 -->
                    </hc:PropertyGrid>
                    <Separator Margin="0,15" Background="{StaticResource BorderBrush}" />
                    <TextBlock Text="源: SQL Server (192.168.1.10)" Margin="0,5" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="目标: MySQL (Cloud_DB_01)" Margin="0,5" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="转换规则: 3 条已启用" Margin="0,5" Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
