<Window x:Class="DataMigration.Wpf.PluginSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DataMigration.Wpf"
        xmlns:vm="clr-namespace:DataMigration.Wpf.ViewModel"
        mc:Ignorable="d"
        Title="选择插件"
        Height="600"
        Width="800"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance Type=vm:PluginSelectionViewModel, IsDesignTimeCreatable=True}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 插件类型选择 -->
        <Grid Grid.Row="0" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="150" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="插件类型：" VerticalAlignment="Center" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding PluginTypes}"
                      SelectedIndex="{Binding SelectedPluginTypeIndex}" />
        </Grid>

        <!-- 插件列表 -->
        <ListBox Grid.Row="1" Margin="10"
                 ItemsSource="{Binding FilteredPlugins}"
                 SelectedItem="{Binding SelectedPlugin}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{Binding Name}" FontWeight="Bold" />
                        <TextBlock Grid.Row="1" Text="{Binding Id, StringFormat='ID: {0}'}" FontSize="12" Foreground="Gray" />
                        <TextBlock Grid.Row="2" Text="{Binding Version, StringFormat='版本: {0}'}" FontSize="12" Foreground="Gray" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 按钮区域 -->
        <Grid Grid.Row="2" Margin="10" HorizontalAlignment="Right">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="100" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="取消" Click="CancelButton_Click" IsCancel="True" />
            <Button Grid.Column="1" Content="确定" Click="ConfirmButton_Click" IsDefault="True" Margin="10,0,0,0" />
        </Grid>
    </Grid>
</Window>