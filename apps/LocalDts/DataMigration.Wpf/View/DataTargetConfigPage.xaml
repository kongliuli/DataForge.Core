<Page x:Class="DataMigration.Wpf.DataTargetConfigPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:DataMigration.Wpf"
      xmlns:converters="clr-namespace:DataMigration.Wpf.Converters"
      xmlns:vm="clr-namespace:DataMigration.Wpf.ViewModel"
      mc:Ignorable="d"
      d:DesignHeight="800"
      d:DesignWidth="1000"
      d:DataContext="{d:DesignInstance Type=vm:DataTargetConfigViewModel, IsDesignTimeCreatable=True}"
      Title="目标源配置">
    <Page.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    </Page.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        
        <!-- 左侧：目标源列表和已保存配置 -->
        <Grid Grid.Column="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" Text="目标源列表" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
            <ListBox Grid.Row="1" ItemsSource="{Binding DataTargets}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedDataTarget}" Margin="0,0,0,20" />
            
            <TextBlock Grid.Row="2" Text="已保存的配置" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
            <ListBox Grid.Row="3" ItemsSource="{Binding SavedConfigs}" SelectedItem="{Binding SelectedConfig}" DisplayMemberPath="Name">
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="删除配置" Command="{Binding DeleteConfigCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}, Mode=FindAncestor}, Path=DataContext}" />
                    </ContextMenu>
                </ListBox.ContextMenu>
            </ListBox>
        </Grid>
        
        <!-- 右侧：配置表单和数据预览 -->
        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" Text="目标源配置" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" />
            
            <Grid Grid.Row="1" Margin="0,10,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="400" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="配置名称:" VerticalAlignment="Center" />
                <TextBox Grid.Column="1" Text="{Binding ConfigName, Mode=TwoWay}" />
            </Grid>
            
            <ItemsControl Grid.Row="2" ItemsSource="{Binding ConfigProperties}" Margin="0,10,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,5,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="400" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding Value, Mode=TwoWay}" />
                            <Button Grid.Column="2" Content="浏览..." Visibility="{Binding Name, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter='DatabasePath,FilePath'}" Command="{Binding DataContext.BrowseCommand, RelativeSource={RelativeSource AncestorType={x:Type Page}}}" CommandParameter="{Binding}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            
            <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" Foreground="Red" Margin="0,10,0,0" />
            
            <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,20,0,0">
                <Button Content="保存配置" Command="{Binding SaveCommand}" Margin="0,0,10,0" Width="120" Height="30" />
                <Button Content="测试连接" Command="{Binding TestConnectionCommand}" IsEnabled="{Binding !IsTestingConnection}" Margin="0,0,10,0" Width="120" Height="30" />
                <Button Content="预览数据" Command="{Binding PreviewDataCommand}" IsEnabled="{Binding !IsPreviewing}" Margin="0,0,10,0" Width="120" Height="30" />
            </StackPanel>
            
            <Grid Grid.Row="5" Margin="0,10,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="150" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="测试结果:" FontSize="14" FontWeight="Bold" Margin="0,0,0,5" />
                <TextBlock Grid.Row="1" Text="{Binding TestConnectionResult}" Margin="0,0,0,10">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="Black" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding TestConnectionResult}" Value="连接成功！">
                                    <Setter Property="Foreground" Value="Green" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding TestConnectionResult}" Value="连接成功！目标数据库已准备就绪">
                                    <Setter Property="Foreground" Value="Green" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding TestConnectionResult}" Value="连接成功！目标文件路径有效">
                                    <Setter Property="Foreground" Value="Green" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding TestConnectionResult}" Value="正在测试连接...">
                                    <Setter Property="Foreground" Value="Blue" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding TestConnectionResult, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=连接失败:}" Value="Visible">
                                    <Setter Property="Foreground" Value="Red" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <StackPanel Grid.Row="2" Margin="0,5,0,0">
                    <TextBlock Text="数据表结构" FontSize="14" FontWeight="Bold" Margin="0,0,0,5" />
                    <ListBox ItemsSource="{Binding TableList}" Height="130" />
                </StackPanel>
            </Grid>
            
            <Grid Grid.Row="6" Margin="0,10,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="预览结果:" FontSize="14" FontWeight="Bold" Margin="0,0,0,5" />
                <TextBlock Grid.Row="1" Text="{Binding PreviewResult}" Margin="0,0,0,10" />
            </Grid>
            
            <DataGrid Grid.Row="6" ItemsSource="{Binding PreviewData}" AutoGenerateColumns="True" Margin="0,10,0,0" CanUserSortColumns="True" />
        </Grid>
    </Grid>
</Page>