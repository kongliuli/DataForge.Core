{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "WebDts": {
    "PluginsDirectory": "Plugins",
    "UploadDirectory": "Uploads",
    "MaxFileSize": 104857600,
    "AllowedFileTypes": [".csv", ".xlsx", ".xls", ".json", ".xml"]
  },
  "Jwt": {
    "Key": "YourSecretKeyHere-ReplaceWithSecureKey",
    "Issuer": "WebDts.Blazor",
    "Audience": "WebDts.Users",
    "ExpirationHours": 24
  }
}
