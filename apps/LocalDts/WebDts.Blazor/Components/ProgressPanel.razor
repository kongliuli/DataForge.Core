@using AntDesign

<div class="progress-panel" style="margin: 16px 0;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
        <span>@Title</span>
        <span style="color: #666; font-size: 12px;">@Progress% 完成</span>
    </div>
    <Progress 
        Percent="@Progress" 
        Status="@GetProgressStatus()" 
        StrokeColor="@StrokeColor"
    />
    @if (!string.IsNullOrEmpty(Message))
    {
        <div style="margin-top: 8px; font-size: 12px; color: #666;">
            @Message
        </div>
    }
</div>

@code {
    [Parameter]
    public string Title { get; set; } = "执行进度";

    [Parameter]
    public int Progress { get; set; } = 0;

    [Parameter]
    public string Message { get; set; } = string.Empty;

    [Parameter]
    public string StrokeColor { get; set; } = "";

    [Parameter]
    public bool IsSuccess { get; set; } = false;

    [Parameter]
    public bool IsError { get; set; } = false;

    private AntDesign.ProgressStatus GetProgressStatus()
    {
        if (IsError)
        {
            return AntDesign.ProgressStatus.Exception;
        }
        if (IsSuccess || Progress >= 100)
        {
            return AntDesign.ProgressStatus.Success;
        }
        if (Progress > 0)
        {
            return AntDesign.ProgressStatus.Active;
        }
        return AntDesign.ProgressStatus.Normal;
    }
}